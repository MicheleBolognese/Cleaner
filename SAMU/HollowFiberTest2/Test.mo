    annotation(Documentation(info="<html><p>This model has dry air and wet air fluxes flow in the right channels, with dry air thorugh the tubes and wet air inside the shell, accordingly to the orientation for positive and negative flux set by m_trans = f(Fick's law).</p></html>"),Icon(coordinateSystem(preserveAspectRatio = false,extent = {{-100.0,-100.0},{100.0,100.0}}),graphics = {Rectangle(lineColor={0,0,0},fillColor={230,230,230},fillPattern=FillPattern.Solid,extent={{-100.0,-100.0},{100.0,100.0}}),Text(lineColor={0,0,255},extent={{-150,150},{150,110}},textString="%name")}));
